{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "../types/src/lib/category.ts",
    "../types/src/lib/paginated.ts",
    "../types/src/lib/product.ts",
    "../types/src/lib/index.ts"
  ],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
